<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="48dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose Your Plan"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One tap to activate automatic parametric protection"
                android:textSize="14sp"
                android:textColor="#8892A4"
                android:layout_marginBottom="28dp"/>

            <!-- Basic Plan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_basic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#141929"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Basic Shield" android:textColor="#F0F4FF" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹99/wk" android:textColor="#00E5CC" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Coverage up to ₹10,000" android:textColor="#C8D0E0" android:textSize="14sp" android:layout_marginTop="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_basic"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Select Basic"
                        app:backgroundTint="#2D3748"
                        app:cornerRadius="8dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Standard Plan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_standard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#00E5CC"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Standard Shield" android:textColor="#0A0E1A" android:textSize="20sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹149/wk" android:textColor="#0A0E1A" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Coverage up to ₹25,000\n+ Rain Disruption Tracking" android:textColor="#1A4040" android:textSize="14sp" android:layout_marginTop="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_standard"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Select Standard"
                        android:textColor="#F0F4FF"
                        app:backgroundTint="#0A0E1A"
                        app:cornerRadius="8dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Premium Plan -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_premium"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#141929"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Premium Shield" android:textColor="#F0F4FF" android:textSize="18sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="₹199/wk" android:textColor="#FFB020" android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Coverage up to ₹50,000\n+ Rain + Extreme Logic + Priority Payout" android:textColor="#C8D0E0" android:textSize="14sp" android:layout_marginTop="8dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_premium"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Select Premium"
                        android:textColor="#0A0E1A"
                        app:backgroundTint="#FFB020"
                        app:cornerRadius="8dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>