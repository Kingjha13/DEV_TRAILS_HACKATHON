<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="-60dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_glow_teal"
        android:alpha="0.2"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:paddingTop="48dp">

            <!-- Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Activate Protection"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#F0F4FF"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="One tap to get covered against disruptions"
                android:textSize="14sp"
                android:textColor="#8892A4"
                android:layout_marginBottom="28dp"/>

            <!-- Plan summary hero card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#00E5CC"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        <TextView
                            android:id="@+id/tv_plan_tier"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Medium Plan"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#0A0E1A"
                            android:fontFamily="sans-serif-medium"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🛡"
                            android:textSize="32sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Weekly Premium"
                                android:textSize="12sp"
                                android:textColor="#1A4040"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tv_premium_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#0A0E1A"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="60dp"
                            android:background="#1A4040"
                            android:layout_gravity="center_vertical"
                            android:layout_marginHorizontal="16dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Max Payout"
                                android:textSize="12sp"
                                android:textColor="#1A4040"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:id="@+id/tv_coverage_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹--"
                                android:textSize="34sp"
                                android:textStyle="bold"
                                android:textColor="#0A0E1A"
                                android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- What's covered -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#141929"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="What's Covered"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#F0F4FF"
                        android:layout_marginBottom="16dp"/>

                    <!-- Coverage items -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="🌧" android:textSize="18sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Heavy rain &amp; flooding disruption"
                            android:textColor="#C8D0E0" android:textSize="14sp" android:paddingStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="🌫" android:textSize="18sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Hazardous AQI affecting work"
                            android:textColor="#C8D0E0" android:textSize="14sp" android:paddingStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="🚦" android:textSize="18sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Severe traffic &amp; route disruption"
                            android:textColor="#C8D0E0" android:textSize="14sp" android:paddingStart="12dp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="24dp" android:layout_height="wrap_content"
                            android:text="⚡" android:textSize="18sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Auto-claim · UPI payout within 24hrs"
                            android:textColor="#00E5CC" android:textSize="14sp" android:paddingStart="12dp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Security note -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="24dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔒" android:textSize="14sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="  Secured by Razorpay · 256-bit encryption"
                    android:textSize="12sp" android:textColor="#8892A4"/>
            </LinearLayout>

            <!-- Pay button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_pay"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Pay &amp; Activate →"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#0A0E1A"
                app:backgroundTint="#00E5CC"
                app:cornerRadius="16dp"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>