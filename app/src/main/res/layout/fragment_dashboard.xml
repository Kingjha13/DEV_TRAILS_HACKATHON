<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="visible"/>

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="20dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛡 ShieldNet" android:textSize="22sp"
                        android:textStyle="bold" android:textColor="@color/shieldnet_teal"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Dashboard" android:textSize="14sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ar_nav"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="AR Nav"
                    android:textSize="12sp"
                    app:backgroundTint="@color/card_bg"
                    app:icon="@drawable/ic_ar"/>
            </LinearLayout>

            <!-- Trigger Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_trigger"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">
                    <ImageView android:id="@+id/iv_trigger_icon" android:layout_width="40dp"
                        android:layout_height="40dp" android:src="@drawable/ic_shield_check"
                        android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_trigger_title" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="All Clear ✓"
                            android:textSize="16sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:id="@+id/tv_trigger_desc" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:textSize="13sp"
                            android:textColor="@color/white" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Active Policy Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_policy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/tv_policy_tier" android:layout_width="0dp"
                            android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="MEDIUM PLAN" android:textSize="18sp"
                            android:textStyle="bold" android:textColor="@color/shieldnet_teal"/>
                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_policy_status"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ACTIVE" android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView android:id="@+id/tv_policy_coverage" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_primary"
                        android:textSize="22sp" android:textStyle="bold" android:layout_marginTop="8dp"/>
                    <TextView android:id="@+id/tv_policy_expiry" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                        android:textSize="13sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- No Policy CTA -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_no_policy_cta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                android:layout_marginBottom="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="You are not covered" android:textSize="18sp"
                        android:textStyle="bold" android:textColor="@color/text_primary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Get protected against weather disruptions" android:textSize="13sp"
                        android:textColor="@color/text_secondary" android:layout_marginTop="4dp"
                        android:layout_marginBottom="16dp"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_buy_policy_cta"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:text="Get Covered Now" app:backgroundTint="@color/shieldnet_teal"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Claims Section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Claims History" android:textSize="18sp"
                android:textStyle="bold" android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <TextView android:id="@+id/tv_no_claims_msg" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="No claims yet."
                android:textColor="@color/text_secondary" android:visibility="gone"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_claims"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</FrameLayout>
