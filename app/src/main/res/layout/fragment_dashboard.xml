<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0E1A">

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="#00E5CC"/>

    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡 ShieldNet"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#00E5CC"
                        android:fontFamily="sans-serif-medium"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your protection dashboard"
                        android:textSize="13sp"
                        android:textColor="#8892A4"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ar_nav"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="AR Nav"
                    android:textSize="12sp"
                    android:textColor="#00E5CC"
                    app:backgroundTint="#141929"
                    app:cornerRadius="20dp"
                    app:strokeColor="#00E5CC"
                    app:strokeWidth="1dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_trigger"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#0D3D2E"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="18dp"
                        android:gravity="center_vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:cardBackgroundColor="#00E5CC"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:id="@+id/iv_trigger_icon"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@drawable/ic_shield_check"
                                android:padding="10dp"
                                app:tint="#0A0E1A" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:id="@+id/tv_trigger_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="All Clear ✓"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#00E5CC"/>
                            <TextView
                                android:id="@+id/tv_trigger_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="No disruptions detected in your area"
                                android:textSize="13sp"
                                android:textColor="#8892A4"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_policy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#00E5CC"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:id="@+id/tv_policy_tier"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="MEDIUM PLAN"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1A4040"
                                android:letterSpacing="0.1"/>
                            <com.google.android.material.chip.Chip
                                android:id="@+id/chip_policy_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ACTIVE"
                                android:textSize="11sp"
                                android:textColor="#0A0E1A"
                                app:chipBackgroundColor="#0A0E1A"
                                app:chipMinHeight="28dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_policy_coverage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#0A0E1A"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp"/>
                        <TextView
                            android:id="@+id/tv_policy_expiry"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1A4040"
                            android:textSize="13sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/card_no_policy_cta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="#141929"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="24dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="You're not covered"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#F0F4FF"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠️"
                                android:textSize="22sp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="A weather event today means zero income. Get protected in under 2 minutes."
                            android:textSize="13sp"
                            android:textColor="#8892A4"
                            android:lineSpacingExtra="3dp"
                            android:layout_marginBottom="16dp"/>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_buy_policy_cta"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Get Covered Now →"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#0A0E1A"
                            app:backgroundTint="#00E5CC"
                            app:cornerRadius="12dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Claims History"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#F0F4FF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Auto-processed"
                        android:textSize="12sp"
                        android:textColor="#8892A4"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_no_claims_msg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No claims yet — stay safe out there! 🙌"
                    android:textColor="#8892A4"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:paddingVertical="24dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_claims"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="24dp"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</FrameLayout>